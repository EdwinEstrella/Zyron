{
  "name": "zyron",
  "version": "1.0.1",
  "description": "Aplicacion para facturacion",
  "author": "Edwin",
  "main": "main.js",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "make:win": "electron-forge make --platform=win32",
    "make:win:icon": "npm run make:win && node ./scripts/after-pack-exe-icon.cjs",
    "qa:saas": "node ./scripts/smoke-saas.cjs",
    "dist:win": "electron-builder --win",
    "release:win": "electron-builder --win --publish always"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-wix": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@insforge/cli": "^0.1.70",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "rcedit": "^5.0.2"
  },
  "dependencies": {
    "@insforge/sdk": "^1.2.5",
    "dotenv": "^16.6.1",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.3"
  },
  "build": {
    "appId": "com.edwin.zyron",
    "productName": "Zyron",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "package.json",
      "logo.ico",
      "logo.png",
      ".env",
      "components/**/*",
      "fragments/**/*",
      "public/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "logo.ico",
        "to": "logo.ico"
      }
    ],
    "asar": true,
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "logo.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "artifactName": "Zyron-Install.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "logo.ico",
      "uninstallerIcon": "logo.ico",
      "installerHeaderIcon": "logo.ico",
      "runAfterFinish": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false,
      "warningsAsErrors": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "EdwinEstrella",
        "repo": "Zyron",
        "releaseType": "release",
        "vPrefixedTagName": true
      }
    ]
  }
}
