{
  "name": "zyron",
  "version": "1.0.1",
  "description": "Aplicacion para facturacion",
  "author": "Edwin",
  "main": "main.js",
  "scripts": {
    "start": "electron-forge start",
    "lint": "eslint .",
    "format:check": "prettier . --check",
    "format": "prettier . --write",
    "prepare": "husky",
    "build:css": "tailwindcss -c ./tailwind.config.cjs -i ./styles/tailwind.css -o ./public/tailwind.css --minify",
    "build:runtime-config": "node ./scripts/write-insforge-config.cjs",
    "build:runtime-config:required": "node ./scripts/write-insforge-config.cjs --require",
    "prepackage": "npm run build:css && npm run build:runtime-config:required",
    "package": "electron-forge package",
    "premake": "npm run build:css && npm run build:runtime-config:required",
    "make": "electron-forge make",
    "make:win": "electron-forge make --platform=win32",
    "make:win:icon": "npm run make:win && node ./scripts/after-pack-exe-icon.cjs",
    "qa:saas": "npm run build:css && node ./scripts/smoke-saas.cjs",
    "test:behavior": "node --test tests/behavior/*.test.cjs",
    "test:e2e": "playwright test",
    "ci": "npm run qa:saas && npm run test:behavior && npm run test:e2e",
    "predist:win": "npm run build:css && npm run build:runtime-config:required",
    "dist:win": "electron-builder --win",
    "prerelease:win": "npm run build:css && npm run build:runtime-config:required",
    "release:win": "electron-builder --win --publish always"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-wix": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@eslint/js": "^10.0.1",
    "@insforge/cli": "^0.1.81",
    "@playwright/test": "1.60.0",
    "@tailwindcss/container-queries": "0.1.1",
    "@tailwindcss/forms": "0.5.10",
    "electron": "^41.6.1",
    "electron-builder": "^26.8.1",
    "eslint": "^10.4.0",
    "eslint-plugin-security": "^4.0.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "rcedit": "^5.0.2",
    "tailwindcss": "3.4.17"
  },
  "dependencies": {
    "@insforge/sdk": "^1.2.9",
    "dotenv": "^16.6.1",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.3"
  },
  "lint-staged": {
    "*.{js,cjs,mjs}": [
      "eslint --fix --no-warn-ignored",
      "prettier --write --ignore-unknown"
    ],
    "*.{json,md,yml,yaml,css,html}": "prettier --write --ignore-unknown"
  },
  "overrides": {
    "@electron/rebuild": "4.0.4",
    "@xmldom/xmldom": "0.8.13",
    "fast-uri": "3.1.2",
    "tar": "7.5.15",
    "ws": "8.20.1"
  },
  "build": {
    "appId": "com.edwin.zyron",
    "productName": "Zyron",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "package.json",
      "logo.ico",
      "logo.png",
      "!.env",
      "!.env.*",
      "!**/.env",
      "!**/.env.*",
      "!**/*credentials*.json",
      "!**/*secret*.json",
      "components/**/*",
      "fragments/**/*",
      "public/**/*",
      "!public/zyron-legacy.html",
      ".generated/insforge.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "logo.ico",
        "to": "logo.ico"
      },
      {
        "from": ".generated/insforge.json",
        "to": "insforge.json"
      }
    ],
    "asar": true,
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "logo.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "artifactName": "Zyron-Install.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "logo.ico",
      "uninstallerIcon": "logo.ico",
      "installerHeaderIcon": "logo.ico",
      "runAfterFinish": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false,
      "warningsAsErrors": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "EdwinEstrella",
        "repo": "Zyron",
        "releaseType": "release",
        "vPrefixedTagName": true
      }
    ]
  }
}
